# PostgreSQL (Supabase or local). Use asyncpg driver for this app.
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# Optional: sync URL for Alembic/scripts (postgresql:// without +asyncpg)
# DATABASE_URL_SYNC=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

SECRET_KEY=change-me-to-at-least-32-random-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Upstash Redis (TLS)
REDIS_URL=rediss://default:YOUR_TOKEN@YOUR-ENDPOINT.upstash.io:6379

# Cloudinary — profile photos and resume PDFs
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Comma-separated origins, or * for development
CORS_ORIGINS=http://localhost:3000
